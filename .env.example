# Wallet private key (EOA that controls your Polymarket proxy wallet)
PRIVATE_KEY=0x...

# Fixed USD amount per trade
TRADE_AMOUNT_USD=50

# Maximum total budget before stopping
MAX_BUDGET_USD=1000

# API hosts (defaults shown — only override for testnet)
CLOB_HOST=https://clob.polymarket.com
GAMMA_HOST=https://gamma-api.polymarket.com
